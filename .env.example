PORT=3000
TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_POLL_RETRY_DELAY_MS=1000

# pi-mono LLM configuration. Provider/model IDs follow the pi-coding-agent
# registry (see https://github.com/badlogic/pi-mono). Set the API key
# variable that matches your chosen provider.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=sk-ant-replace-with-your-key

# ---- Built-in providers (no LLM_BASE_URL needed) ----
# Examples for other providers (uncomment and replace LLM_PROVIDER/LLM_MODEL
# above accordingly):
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-replace-with-your-key
#
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.5-pro
# GOOGLE_API_KEY=replace-with-your-key
#
# OpenRouter is built-in. Use pi-mono's canonical model IDs (run
# `npx pi --list-models openrouter` to see the full list; IDs may differ
# slightly from openrouter.ai's own naming).
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_API_KEY=sk-or-v1-replace-with-your-key

# ---- Custom OpenAI-compatible providers (set LLM_BASE_URL + LLM_API_KEY) ----
# When LLM_BASE_URL is set, the bot registers LLM_PROVIDER as a custom
# OpenAI-compatible provider with that endpoint and uses LLM_API_KEY for auth.
# Works for Requesty, LiteLLM, vLLM, LM Studio, Ollama, or any compatible gateway.
#
# Requesty (https://requesty.ai)
# LLM_PROVIDER=requesty
# LLM_MODEL=anthropic/claude-sonnet-4-5
# LLM_BASE_URL=https://router.requesty.ai/v1
# LLM_API_KEY=sk-replace-with-your-requesty-key

# ---- Tools ----
# Per-chat scratch workspace root. The agent's read/write/edit tools operate
# under WORKSPACE_ROOT/<chatId>/. Defaults to ./data/workspaces (relative to
# the bot's cwd; in Docker that is /app/data/workspaces).
# WORKSPACE_ROOT=./data/workspaces

# Path to the system prompt file. Defaults to ./prompts/SYSTEM.md. Edit that
# file to change the bot's persona and instructions; if the file is missing
# or empty, a built-in fallback prompt is used.
# SYSTEM_PROMPT_PATH=./prompts/SYSTEM.md

# Web search via Exa (https://exa.ai). When set, the agent gets a `web_search`
# tool. Without this key, web_search is disabled but `web_fetch` (Jina Reader,
# keyless) is still available.
# EXA_API_KEY=replace-with-your-exa-key

# Image generation via OpenAI Images. When set, the agent gets a `generate_image`
# tool that creates an image and sends it to the chat via Telegram sendPhoto.
# OPENAI_IMAGE_API_KEY falls back to OPENAI_API_KEY if it isn't set, so a single
# OPENAI_API_KEY is enough if you also use OpenAI for chat.
# OPENAI_API_KEY=sk-replace-with-your-openai-key
# OPENAI_IMAGE_API_KEY=sk-replace-if-different-from-OPENAI_API_KEY
# OPENAI_IMAGE_MODEL=dall-e-3

# GitHub read-only tools (github_search_repos, github_search_issues,
# github_get_issue, github_get_readme). Token is optional - unauthenticated
# requests work but are rate-limited to 60/hour (10/min for search). A
# fine-grained PAT with public_repo scope is enough for read-only use.
# GITHUB_TOKEN=ghp_replace-with-your-token

# Vercel read-only tools (vercel_list_projects, vercel_list_deployments,
# vercel_get_deployment). Create a token at https://vercel.com/account/tokens.
# VERCEL_TEAM_ID is optional and scopes every request to a specific team.
# VERCEL_TOKEN=replace-with-your-vercel-token
# VERCEL_TEAM_ID=team_xxxxxxxx

# Railway read-only tools (railway_list_projects, railway_get_project).
# Use a personal/team API token from https://railway.com/account/tokens.
# Project-scoped tokens will NOT work (they cannot list across projects).
# RAILWAY_API_TOKEN=replace-with-your-railway-token

# Travel tools via SerpAPI (https://serpapi.com). When set, the agent gets
# `flight_search` (Google Flights) and `hotel_search` (Google Hotels) tools.
# Prices returned are snapshots, not bookable quotes - users should confirm
# on the airline/hotel/booking site.
# SERPAPI_API_KEY=replace-with-your-serpapi-key
