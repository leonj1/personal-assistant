PORT=3000
TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_POLL_RETRY_DELAY_MS=1000

# pi-mono LLM configuration. Provider/model IDs follow the pi-coding-agent
# registry (see https://github.com/badlogic/pi-mono). Set the API key
# variable that matches your chosen provider.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=sk-ant-replace-with-your-key

# ---- Built-in providers (no LLM_BASE_URL needed) ----
# Examples for other providers (uncomment and replace LLM_PROVIDER/LLM_MODEL
# above accordingly):
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-replace-with-your-key
#
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.5-pro
# GOOGLE_API_KEY=replace-with-your-key
#
# OpenRouter is built-in. Use pi-mono's canonical model IDs (run
# `npx pi --list-models openrouter` to see the full list; IDs may differ
# slightly from openrouter.ai's own naming).
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_API_KEY=sk-or-v1-replace-with-your-key

# ---- Custom OpenAI-compatible providers (set LLM_BASE_URL + LLM_API_KEY) ----
# When LLM_BASE_URL is set, the bot registers LLM_PROVIDER as a custom
# OpenAI-compatible provider with that endpoint and uses LLM_API_KEY for auth.
# Works for Requesty, LiteLLM, vLLM, LM Studio, Ollama, or any compatible gateway.
#
# Requesty (https://requesty.ai)
# LLM_PROVIDER=requesty
# LLM_MODEL=anthropic/claude-sonnet-4-5
# LLM_BASE_URL=https://router.requesty.ai/v1
# LLM_API_KEY=sk-replace-with-your-requesty-key

# ---- Tools ----
# Web search via Exa (https://exa.ai). When set, the agent gets a `web_search`
# tool. Without this key, web_search is disabled but `web_fetch` (Jina Reader,
# keyless) is still available.
# EXA_API_KEY=replace-with-your-exa-key

