PORT=3000
TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_POLL_RETRY_DELAY_MS=1000

# pi-mono LLM configuration. Provider/model IDs follow the pi-coding-agent
# registry (see https://github.com/badlogic/pi-mono). Set the API key
# variable that matches your chosen provider.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=sk-ant-replace-with-your-key

# ---- Built-in providers (no LLM_BASE_URL needed) ----
# Examples for other providers (uncomment and replace LLM_PROVIDER/LLM_MODEL
# above accordingly):
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-replace-with-your-key
#
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.5-pro
# GOOGLE_API_KEY=replace-with-your-key
#
# OpenRouter is built-in. Use pi-mono's canonical model IDs (run
# `npx pi --list-models openrouter` to see the full list; IDs may differ
# slightly from openrouter.ai's own naming).
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_API_KEY=sk-or-v1-replace-with-your-key

# ---- Custom OpenAI-compatible providers (set LLM_BASE_URL + LLM_API_KEY) ----
# When LLM_BASE_URL is set, the bot registers LLM_PROVIDER as a custom
# OpenAI-compatible provider with that endpoint and uses LLM_API_KEY for auth.
# Works for Requesty, LiteLLM, vLLM, LM Studio, Ollama, or any compatible gateway.
#
# Requesty (https://requesty.ai)
# LLM_PROVIDER=requesty
# LLM_MODEL=anthropic/claude-sonnet-4-5
# LLM_BASE_URL=https://router.requesty.ai/v1
# LLM_API_KEY=sk-replace-with-your-requesty-key

# ---- Tools ----
# Per-chat scratch workspace root. The agent's read/write/edit tools operate
# under WORKSPACE_ROOT/<chatId>/. Defaults to ./data/workspaces (relative to
# the bot's cwd; in Docker that is /app/data/workspaces).
# WORKSPACE_ROOT=./data/workspaces

# Prompt profile is selected at launch, not by env var:
#   node dist/index.js --profile assistant
#   node dist/index.js --profile staff
# The app reads ./prompts/<profile>/SYSTEM.md and ./prompts/<profile>/TOOLS.md.
# SYSTEM.md for the chosen profile must exist and be non-empty or startup fails.
# TOOLS.md for the chosen profile is optional; missing is logged once and ignored.

# Web search via Exa (https://exa.ai). When set, the agent gets a `web_search`
# tool. Without this key, web_search is disabled but `web_fetch` (Jina Reader,
# keyless) is still available.
# EXA_API_KEY=replace-with-your-exa-key

# Image generation via OpenAI Images. When set, the agent gets a `generate_image`
# tool that creates an image and sends it to the chat via Telegram sendPhoto.
# OPENAI_IMAGE_API_KEY falls back to OPENAI_API_KEY if it isn't set, so a single
# OPENAI_API_KEY is enough if you also use OpenAI for chat.
# OPENAI_API_KEY=sk-replace-with-your-openai-key
# OPENAI_IMAGE_API_KEY=sk-replace-if-different-from-OPENAI_API_KEY
# OPENAI_IMAGE_MODEL=dall-e-3

# GitHub read-only tools (github_search_repos, github_search_issues,
# github_get_issue, github_get_readme). Token is optional - unauthenticated
# requests work but are rate-limited to 60/hour (10/min for search). A
# fine-grained PAT with public_repo scope is enough for read-only use.
# GITHUB_TOKEN=ghp_replace-with-your-token

# Vercel read-only tools (vercel_list_projects, vercel_list_deployments,
# vercel_get_deployment). Create a token at https://vercel.com/account/tokens.
# VERCEL_TEAM_ID is optional and scopes every request to a specific team.
# VERCEL_TOKEN=replace-with-your-vercel-token
# VERCEL_TEAM_ID=team_xxxxxxxx

# Railway read-only tools (railway_list_projects, railway_get_project).
# Use a personal/team API token from https://railway.com/account/tokens.
# Project-scoped tokens will NOT work (they cannot list across projects).
# RAILWAY_API_TOKEN=replace-with-your-railway-token

# Travel tools via SerpAPI (https://serpapi.com). When set, the agent gets
# `flight_search` (Google Flights) and `hotel_search` (Google Hotels) tools.
# Prices returned are snapshots, not bookable quotes - users should confirm
# on the airline/hotel/booking site.
# SERPAPI_API_KEY=replace-with-your-serpapi-key

# DevBoxer tools (devboxer_create, devboxer_list, devboxer_pull) are auto-
# enabled when the `devboxer` CLI is on PATH. Setup on the bot host:
#   npm install -g @devboxer/cli
#   devboxer auth          # one-time, opens a browser
# In Docker, install the CLI in your image and mount the operator's auth
# directory (typically ~/.devboxer) into the container, since `devboxer auth`
# is a browser-based one-time flow that cannot run inside the container.
# DEVBOXER_BINARY=devboxer

# ---- Missions / staff (personal-assistant-missions integration) ----
# When MISSIONS_API_URL is set, the agent gets:
#   - mission_create_mission / mission_create_project / mission_create_task
#   - staff_list / staff_create / staff_delegate
# The bot also exposes POST /messenger/dispatch for the watcher's messenger
# to forward Kafka events; see ../personal-assistant-watcher/README.md for
# the payload contract.
# MISSIONS_API_URL=http://localhost:8081

# Bearer token required on POST /messenger/dispatch. Leave empty to disable
# auth on that route (only safe if the watcher and bot share a private network).
# MESSENGER_INBOUND_TOKEN=replace-with-shared-secret

# Telegram chat that receives autonomous (messenger-driven) messages and
# fallback prompts when the watcher cannot resolve a staff member. Required
# if you want autonomous notifications to reach a human; otherwise messenger
# events are logged and dropped.
# DEFAULT_TELEGRAM_CHAT_ID=123456789

# ---- Notes scheduler (notes service integration) ----
# When NOTES_API_URL is set, the agent gets `schedule_list`, `schedule_create`,
# and `schedule_delete` tools. These let the bot register recurring scripts
# in the notes scheduler so it can wake itself up on a cron without the user
# pinging it. Use a host:port reachable from the bot container; the value
# below works when notes is running on the host's port 18080 and the bot is
# in a Docker container.
# NOTES_API_URL=http://host.docker.internal:18080

# URL the notes scheduler should curl to wake the bot. The bot's
# schedule_create tool description references this so the LLM puts the right
# URL in script_path. Default for typical Docker setups: bot on the host's
# port 3000 reachable from inside the notes container as host.docker.internal.
# SCHEDULER_TRIGGER_URL_FROM_NOTES=http://host.docker.internal:3000/scheduler/trigger

# Bearer token required on POST /scheduler/trigger. Leave empty to disable
# auth on that route (only safe if notes and bot share a private network).
# Mirror this value into the curl command the LLM puts in script_path.
# SCHEDULER_TRIGGER_TOKEN=replace-with-shared-secret

# ---- Email (Mailtrap or Resend) ----
# When MAILTRAP_API_KEY is set, the agent gets the `email_send` tool wired to
# Mailtrap's "Email Sending" API (https://send.api.mailtrap.io/api/send). The
# domain in EMAIL_FROM must be verified in Mailtrap. Optionally override the
# endpoint with MAILTRAP_API_URL (e.g. for the sandbox / inbox-testing API
# https://sandbox.api.mailtrap.io/api/send/<inbox_id>).
# MAILTRAP_API_KEY=replace-with-your-mailtrap-token
# MAILTRAP_API_URL=https://send.api.mailtrap.io/api/send
#
# Otherwise, when RESEND_API_KEY is set, the tool uses Resend
# (https://resend.com). EMAIL_FROM must be on a domain verified in Resend.
# RESEND_API_KEY=re_replace-with-your-resend-key
#
# EMAIL_FROM is the default From address (string form: bare email or
# "Name <email@domain>"). Recommended; if unset, the LLM must pass `from` on
# every call.
# EMAIL_FROM=Personal Assistant <bot@your-verified-domain.com>
